{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "type": "process",
      "command": "npm",
      "args": ["run", "build"],
      "group": "build"
    },
    {
      "label": "test",
      "type": "process",
      "command": "npm",
      "args": ["run", "test"],
      "group": "test"
    },
    {
      "label": "lint",
      "type": "process",
      "command": "npm",
      "args": ["run", "lint"],
      "problemMatcher": {
        "owner": "oxlint",
        "source": "oxlint",
        "severity": "error",
        "fileLocation": [
          "relative",
          "${workspaceFolder}"
        ],
        "pattern": [
          {
            "regexp": "^\\s+!\\s+([^\\(]+)\\(([^\\)]+)\\):\\s+(.*)$",
            "code": 2,
            "message": 3
          },
          {
            "regexp": "^\\s+,-\\[(.+):(\\d+):(\\d+)\\]$",
            "file": 1,
            "line": 2,
            "column": 3
          }
        ]
      }
    },
    {
      "label": "show-input",
      "type": "process",
      "command": "node",
      "args": [
        "-e",
        "console.log('message=' + process.argv[1] + ' mode=' + process.argv[2])",
        "${env:DEMO_MESSAGE}",
        "${env:DEMO_MODE}"
      ]
    }
  ]
}
