{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "type": "npm",
      "script": "build",
      "group": "build"
    },
    {
      "label": "test",
      "type": "npm",
      "script": "test",
      "group": "test"
    },
    {
      "label": "lint",
      "type": "npm",
      "script": "lint",
      "problemMatcher": {
        "owner": "oxlint",
        "source": "oxlint",
        "severity": "error",
        "fileLocation": [
          "relative",
          "${workspaceFolder}"
        ],
        "pattern": [
          {
            "regexp": "^\\s+!\\s+([^\\(]+)\\(([^\\)]+)\\):\\s+(.*)$",
            "code": 2,
            "message": 3
          },
          {
            "regexp": "^\\s+,-\\[(.+):(\\d+):(\\d+)\\]$",
            "file": 1,
            "line": 2,
            "column": 3
          }
        ]
      }
    }
  ]
}
