{
  "version": "2.0.0",
  "inputs": [
    {
      "id": "demoMessage",
      "type": "promptString",
      "description": "Message to print",
      "default": "hello from main"
    },
    {
      "id": "demoMode",
      "type": "pickString",
      "description": "Select a mode",
      "default": "preview",
      "options": [
        {
          "label": "Preview",
          "value": "preview"
        },
        {
          "label": "Release",
          "value": "release"
        }
      ]
    }
  ],
  "tasks": [
    {
      "label": "build",
      "type": "process",
      "command": "npm",
      "args": ["run", "build"],
      "group": "build"
    },
    {
      "label": "test",
      "type": "process",
      "command": "npm",
      "args": ["run", "test"],
      "group": "test"
    },
    {
      "label": "lint",
      "type": "process",
      "command": "npm",
      "args": ["run", "lint"],
      "problemMatcher": {
        "owner": "oxlint",
        "source": "oxlint",
        "severity": "error",
        "fileLocation": [
          "relative",
          "${workspaceFolder}"
        ],
        "pattern": [
          {
            "regexp": "^\\s+!\\s+([^\\(]+)\\(([^\\)]+)\\):\\s+(.*)$",
            "code": 2,
            "message": 3
          },
          {
            "regexp": "^\\s+,-\\[(.+):(\\d+):(\\d+)\\]$",
            "file": 1,
            "line": 2,
            "column": 3
          }
        ]
      }
    },
    {
      "label": "show-input",
      "type": "process",
      "command": "node",
      "args": [
        "-e",
        "console.log('message=' + process.argv[1] + ' mode=' + process.argv[2])",
        "${input:demoMessage}",
        "${input:demoMode}"
      ]
    },
    {
      "label": "no-checkout-demo",
      "type": "process",
      "command": "node",
      "args": [
        "-e",
        "console.log(JSON.stringify({ task: 'no-checkout-demo', pid: process.pid, node: process.version, platform: process.platform, cwd: process.cwd() }))"
      ]
    },
    {
      "label": "demo-parallel-left",
      "type": "process",
      "command": "node",
      "args": ["scripts/task-step.mjs", "parallel-left", "700"]
    },
    {
      "label": "demo-parallel-right",
      "type": "process",
      "command": "node",
      "args": ["scripts/task-step.mjs", "parallel-right", "1200"]
    },
    {
      "label": "demo-parallel",
      "type": "process",
      "command": "node",
      "args": ["scripts/task-step.mjs", "parallel-join", "200"],
      "dependsOn": ["demo-parallel-left", "demo-parallel-right"]
    },
    {
      "label": "demo-sequence-first",
      "type": "process",
      "command": "node",
      "args": ["scripts/task-step.mjs", "sequence-first", "400"]
    },
    {
      "label": "demo-sequence-second",
      "type": "process",
      "command": "node",
      "args": ["scripts/task-step.mjs", "sequence-second", "400"]
    },
    {
      "label": "demo-sequence",
      "type": "process",
      "command": "node",
      "args": ["scripts/task-step.mjs", "sequence-done", "200"],
      "dependsOn": ["demo-sequence-first", "demo-sequence-second"],
      "dependsOrder": "sequence"
    },
    {
      "label": "demo-mixed",
      "type": "process",
      "command": "node",
      "args": ["scripts/task-step.mjs", "mixed-finish", "150"],
      "dependsOn": ["demo-parallel", "demo-sequence"]
    },
    {
      "label": "scheduled-log",
      "type": "process",
      "command": "npm",
      "args": ["run", "scheduled-log"]
    }
  ]
}
